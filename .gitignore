# Video files — never commit
*.mp4
*.avi
*.mov
*.mkv

# Python
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/

# Virtual environments
.env
.venv
venv/
env/

# Distribution / packaging
*.egg-info/
dist/
build/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Keep .gitkeep files trackable
!**/.gitkeep
